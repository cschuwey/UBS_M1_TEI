<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:tei="http://www.tei-c.org/ns/1.0" xmlns:xs="http://www.w3.org/2001/XMLSchema"
    exclude-result-prefixes="xs" version="2.0">

    <!-- Modèle correspondant à la racine du document -->
    <xsl:template match="/">
        <html>
            <head>
                <style type="text/css">
                        .hidden {
                            display: none;
                        }
                    
                        body {
                            font-family: 'Arial', sans-serif;
                            line-height: 1.6;
                            margin: 20px;
                        }
                    
                        h1 {
                            color: #333;
                        }
                    
                        p {
                            margin-bottom: 15px;
                        }
                </style>
                <title>
                    <!-- Utilisez apply-templates pour extraire le titre de l'ouvrage -->
                    <xsl:apply-templates select="//tei:titleStmt/tei:title"/>
                </title>
            </head>
            <body>
                <h1>
                    <!-- Utilisez apply-templates pour extraire le titre du chapitre -->
                    <xsl:apply-templates select="//tei:div2/tei:head"/>
                </h1>
                <!-- Appliquez les templates pour le contenu du document -->
                <xsl:apply-templates select="//tei:body"/>
                <script type="text/javascript">
                
                        var elems = document.getElementsByClassName("changer");
                        for (var i = elems.length - 1; i >= 0; i--) {
                        elems[i].addEventListener('click', function handleClick(event) {
                        for (var i = this.children.length - 1; i >= 0; i--) {
                        if (this.children[i].classList.contains('hidden')) {
                        this.children[i].classList.remove('hidden');
                        }
                        else {
                        this.children[i].classList.add('hidden');
                        }
                        }
                        
                        });
                        }
                </script>
            </body>
        </html>
    </xsl:template>

    <!-- Modèle pour extraire le titre de l'ouvrage -->
    <xsl:template match="tei:title">
        <xsl:value-of select="."/>
    </xsl:template>

    <!-- Modèle pour extraire le titre du chapitre -->
    <xsl:template match="tei:div2/tei:head">
        <xsl:value-of select="."/>
    </xsl:template>

    <!-- Modèle pour traiter le contenu du document -->
    <xsl:template match="tei:body">
        <!-- Ajoutez ici le traitement du contenu du document en utilisant apply-templates -->
    </xsl:template>

    <!-- Modèles supplémentaires pour les éléments spécifiques du TEI -->

</xsl:stylesheet>
